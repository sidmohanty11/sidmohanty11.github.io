---
import Layout from "../layouts/Layout.astro";
import Blog from "../components/Blog.astro";

const blogs = (await fetch(
  "https://dev.to/api/articles?username=sidmohanty11"
).then((res) => res.json())) as any[];
---

<Layout title="Blogs | Sidharth Mohanty" description="Articles and writing">
  <section class="blogs-hero">
    <p class="hero-eyebrow">Writing</p>
    <h1 class="hero-title">Articles & Insights</h1>
    <p class="hero-desc">
      Thoughts on technology, development, and the lessons I learn along the way.
    </p>

    <div class="stats-row">
      <div class="stat">
        <span class="stat-value">{blogs.length}</span>
        <span class="stat-label">Articles</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="stat-value">{blogs.reduce((a: number, b: any) => a + b.public_reactions_count, 0)}</span>
        <span class="stat-label">Reactions</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="stat-value">{blogs.reduce((a: number, b: any) => a + b.reading_time_minutes, 0)}</span>
        <span class="stat-label">Min Read</span>
      </div>
    </div>
  </section>

  <section class="blogs-grid">
    <div class="grid-header">
      <h2 class="grid-label">All Articles</h2>
    </div>

    <div class="articles-container">
      {blogs.map((blog: any, index: number) => <Blog blog={blog} index={index} />)}
    </div>

    <div class="external-cta">
      <a
        href="https://dev.to/sidmohanty11"
        target="_blank"
        rel="noopener noreferrer"
        class="external-btn"
      >
        View all on Dev.to
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M7 17L17 7M17 7H7M17 7V17"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  .blogs-hero {
    padding: 6rem 0 4rem;
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    animation: fadeInUp 0.6s ease both;
  }

  @media (min-width: 768px) {
    .blogs-hero {
      padding: 8rem 0 5rem;
    }
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6366f1;
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: 2.75rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
    color: #fafafa;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 4rem;
    }
  }

  .hero-desc {
    font-size: 1.05rem;
    color: #71717a;
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto 2.5rem;
  }

  .stats-row {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem 2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.02);
  }

  @media (max-width: 480px) {
    .stats-row {
      gap: 1rem;
      padding: 1rem 1.25rem;
    }
  }

  .stat {
    text-align: center;
  }

  .stat-value {
    display: block;
    font-family: "JetBrains Mono", monospace;
    font-size: 1.5rem;
    font-weight: 500;
    color: #fafafa;
    line-height: 1;
  }

  .stat-label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #52525b;
    margin-top: 0.375rem;
  }

  .stat-sep {
    width: 1px;
    height: 2rem;
    background: rgba(255, 255, 255, 0.08);
  }

  .blogs-grid {
    padding: 3rem 0 4rem;
  }

  .grid-header {
    margin-bottom: 2rem;
  }

  .grid-label {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #71717a;
  }

  .articles-container {
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .articles-container {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .articles-container {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .external-cta {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .external-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    color: #a1a1aa;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .external-btn:hover {
    color: #fafafa;
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.04);
  }

  .external-btn svg {
    width: 16px;
    height: 16px;
    stroke-width: 2;
  }
</style>
