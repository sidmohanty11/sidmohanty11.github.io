---

<Layout title="Projects | Sidharth Mohanty" description="Projects and creations">
  <section class="projects-hero">
    <p class="hero-eyebrow">Projects</p>
    <h1 class="hero-title">Things I've Built</h1>
    <svg class="wavy-accent" viewBox="0 0 120 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M2 6c4-4 8-4 12 0s8 4 12 0 8-4 12 0 8 4 12 0 8-4 12 0 8 4 12 0 8-4 12 0 8 4 12 0 8-4 12 0 8 4 12 0" stroke="url(#wavyGradProj)" stroke-width="2.5" stroke-linecap="round"/>
      <defs>
        <linearGradient id="wavyGradProj" x1="0" y1="6" x2="120" y2="6">
          <stop offset="0%" stop-color="#6366f1"/>
          <stop offset="50%" stop-color="#a78bfa"/>
          <stop offset="100%" stop-color="#818cf8"/>
        </linearGradient>
      </defs>
    </svg>
    <p class="hero-desc">
      Open source projects, apps, and tools. Feel free to explore, contribute, and learn.
    </p>
  </section>

  <section class="projects-section">
    <div class="section-header">
      <h2 class="section-label">Web Apps, CLIs & Libraries</h2>
    </div>
    <div class="web-grid">
      {projects.map((project, index) => <Project project={project} index={index} />)}
    </div>
  </section>

  <section class="projects-section">
    <div class="section-header">
      <h2 class="section-label">Mobile Applications</h2>
    </div>
    <div class="mobile-grid">
      {mobile_projects.map((project, index) => <MobileProject project={project} index={index} />)}
    </div>
  </section>

  <section class="projects-cta">
    <p class="cta-text">Want to see more?</p>
    <a
      href="https://github.com/sidmohanty11"
      target="_blank"
      rel="noopener noreferrer"
      class="cta-btn"
    >
      View GitHub Profile
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
        <path d="M7 17L17 7M17 7H7M17 7V17"/>
      </svg>
    </a>
  </section>
</Layout>

<style>
  .projects-hero {
    padding: 6rem 0 4rem;
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    animation: fadeInUp 0.6s ease both;
  }

  @media (min-width: 768px) {
    .projects-hero {
      padding: 8rem 0 5rem;
    }
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6366f1;
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: 2.75rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
    color: #fafafa;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 4rem;
    }
  }

  .wavy-accent {
    width: 120px;
    height: 12px;
    display: block;
    margin: 0 auto 1.25rem;
    opacity: 0.8;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: #71717a;
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto;
  }

  .projects-section {
    padding: 3rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .section-header {
    margin-bottom: 2rem;
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #71717a;
  }

  .web-grid {
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .web-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .mobile-grid {
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .mobile-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .mobile-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .projects-cta {
    text-align: center;
    padding: 4rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .cta-text {
    font-size: 0.9rem;
    color: #52525b;
    margin-bottom: 1.25rem;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    color: #a1a1aa;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .cta-btn:hover {
    color: #fafafa;
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.04);
  }

  .cta-btn svg {
    width: 16px;
    height: 16px;
    stroke-width: 2;
  }
</style>
