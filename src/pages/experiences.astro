    span: "Nov 2023 - March 2024",
    skills: ["React.js", "Qwik", "TypeScript", "Mitosis", "Builder SDK", "Next.js"],
  },
  {
    id: 12,
    title: "Software Engineer",
    company: '<a href="https://builder.io/" target="_blank">Builder.io</a>',
    description: "Building world-class developer tools and visual development platform.",
    span: "Apr 2024 - present",
    skills: ["React.js", "Qwik", "TypeScript", "Node.js", "Mitosis", "Builder SDK"],
  },
].reverse();
---

<Layout title="Experience | Sidharth Mohanty" description="Professional journey and experience">
  <section class="exp-hero">
    <p class="hero-eyebrow">Experience</p>
    <h1 class="hero-title">Professional Journey</h1>
    <p class="hero-desc">
      3+ years working with startups, open source, and developer tooling companies.
    </p>
  </section>

  <section class="exp-timeline">
    <div class="timeline-wrapper">
      <div class="timeline-line"></div>
      {exp.map((experience, index) => <Experience experience={experience} index={index} />)}
    </div>

    <div class="exp-footer">
      <a href="/story" class="footer-link">
        Read my story
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M7 17L17 7M17 7H7M17 7V17"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  .exp-hero {
    padding: 6rem 0 4rem;
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    animation: fadeInUp 0.6s ease both;
  }

  @media (min-width: 768px) {
    .exp-hero {
      padding: 8rem 0 5rem;
    }
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6366f1;
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: 2.75rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
    color: #fafafa;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 4rem;
    }
  }

  .hero-desc {
    font-size: 1.05rem;
    color: #71717a;
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto;
  }

  .exp-timeline {
    padding: 3rem 0 4rem;
  }

  .timeline-wrapper {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .timeline-line {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(255, 255, 255, 0.06);
  }

  @media (min-width: 768px) {
    .timeline-line {
      left: 0;
    }
  }

  .exp-footer {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    color: #a1a1aa;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .footer-link:hover {
    color: #fafafa;
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.04);
  }

  .footer-link svg {
    width: 16px;
    height: 16px;
    stroke-width: 2;
  }

  :global(.exp-link) {
    color: #818cf8 !important;
    text-decoration: none !important;
    transition: opacity 0.2s ease !important;
  }

  :global(.exp-link:hover) {
    opacity: 0.7 !important;
  }
</style>
