---
import Experience from "../components/Experience.astro";
import Layout from "../layouts/Layout.astro";

let exp = [
  {
    id: 1,
    title: "Open Source Contributor",
    company: '<a href="https://rocket.chat" target="_blank">Rocket.Chat</a>',
    description:
      "Top contributor in GSoC leaderboard 2022 - Rank #1. Selected as Community Member of the Month (June 2022). Contributed to Rocket.Chat, RC4Community, fuselage and RocketChat.js.SDK.",
    span: "Nov 2021 - Sept 2022",
    skills: ["JavaScript", "TypeScript", "Next.js", "Meteor.js", "React.js", "Node.js", "Strapi"],
  },
  {
    id: 2,
    title: "Product Engineer Intern",
    company: '<a href="https://getpropel.app/" target="_blank">Propel</a>',
    description:
      'Built a chrome extension and microservice for scraping LinkedIn connections for <a class="exp-link" href="https://getpropel.app/" target="_blank">getpropel.app</a>. Created the backend and managed deployment.',
    span: "July 2022 - Sept 2022",
    skills: ["Microservices", "AWS Lambda & EC2", "Chrome Extension", "MongoDB", "TypeScript", "Next.js"],
  },
  {
    id: 3,
    title: "Google Summer of Code",
    company: '<a href="https://rocket.chat" target="_blank">Rocket.Chat</a>',
    description:
      'Shipped <a class="exp-link" href="https://github.com/RocketChat/EmbeddedChat" target="_blank">EmbeddedChat</a> - a React.js chat component (npm package). Reached 50+ stars, 87+ forks and 18+ contributors on GitHub.',
    span: "May 2022 - Sept 2022",
    skills: ["JavaScript", "TypeScript", "React.js", "NPM", "Rollup"],
  },
  {
    id: 4,
    title: "React.js SME",
    company: '<a href="https://relevel.com/" target="_blank">Relevel (by Unacademy)</a>',
    description: "React.js Subject Matter Expert - Created questions on React.js and web development for the platform.",
    span: "Sept 2022 - Nov 2022",
    skills: ["React.js", "HTML"],
  },
  {
    id: 5,
    title: "Software Engineer Intern",
    company: '<a href="https://dragonfruit.ai" target="_blank">Dragonfruit AI</a>',
    description:
      "Built folder-like structure for Views, worked on region graphics with pixi.js, wrote cleanup scripts, fixed 20+ tests and made e2e tests 36.06% faster. Regular meetings with co-founders learning about startup operations.",
    span: "Sept 2022 - Dec 2022",
    skills: ["React.js", "TypeScript", "Pixi.js", "Cypress", "Python", "Redux"],
  },
