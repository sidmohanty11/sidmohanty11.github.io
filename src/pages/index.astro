---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";

const lifeUpdates = {
  "2025": [
    { id: 1, title: "Promoted to Software Engineer II at Builder.io" },
  ],
  "2024": [
    { id: 1, title: "Joined Builder.io as a Software Engineer" },
    { id: 2, title: "Google Summer of Code mentor 2024 with Rocket.Chat" },
  ],
  "2023": [
    { id: 9, title: "Got selected for an internship at my dream company - Builder.io" },
    { id: 1, title: "Linux Foundation Mentorship Program 2023 with The Open Mainframe Project" },
    { id: 5, title: "Contributed to Embedchain - an Open Source RAG framework" },
    { id: 2, title: "Google Summer of Code mentor 2023 with Rocket.Chat" },
  ],
  "2022": [
    { id: 3, title: "Google Summer of Code 2022 with Rocket.Chat" },
    { id: 2, title: "Selected as React.js Subject Matter Expert at Relevel" },
    { id: 1, title: "Software Engineer Intern at DragonfruitAI" },
  ],
};

let blogs = (await fetch(
  "https://dev.to/api/articles?username=sidmohanty11"
).then((res) => res.json())) as any[];
blogs = blogs.splice(0, 3);
---

<Layout title="Sidharth Mohanty" description="Software Engineer - Portfolio">
  <Hero />

  <!-- Timeline Section -->
  <section class="section reveal">
    <div class="section-header">
      <div class="section-label-group">
        <span class="section-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
        </span>
        <h2 class="section-label">Timeline</h2>
      </div>
      <a href="/experiences" class="section-action">
        View all
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>

    <div class="glass-panel timeline-panel">
      {
        Object.entries(lifeUpdates)
          .sort(([a], [b]) => parseInt(b) - parseInt(a))
          .map(([year, updates]) => (
            <div class="timeline-group">
              <button
                class={`year-btn ${year === "2025" ? "expanded" : "collapsed"}`}
                data-year={year}
                onclick={`toggleYear('${year}')`}
              >
                <span class="year-label">{year}</span>
                <svg class="chevron-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                  <polyline points="6,9 12,15 18,9"></polyline>
                </svg>
              </button>
              <ul
                class={`timeline-items ${year === "2025" ? "expanded" : "collapsed"}`}
                data-year-content={year}
              >
                {updates.map((u) => (
                  <li class="timeline-entry">
                    <span class="entry-dot"></span>
                    <span class="entry-text">{u.title}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
      }
    </div>
  </section>

  <!-- Featured Talk Section -->
  <section class="section reveal">
    <div class="section-header">
      <div class="section-label-group">
        <span class="section-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polygon points="23,7 16,12 23,17"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
        </span>
        <h2 class="section-label">Featured Talk</h2>
      </div>
      <a
        href="https://www.youtube.com/playlist?list=PL6p5XNtolyav0udwal2UzwP4vqTPXZUDz"
        target="_blank"
        rel="noopener noreferrer"
        class="section-action"
      >
        All talks
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>

    <a
      href="https://www.youtube.com/watch?v=ZDlelRrL-8g&list=PL6p5XNtolyav0udwal2UzwP4vqTPXZUDz"
      target="_blank"
      rel="noopener noreferrer"
      class="talk-card glass-panel"
    >
      <div class="talk-thumbnail">
        <img src="/assets/rc1.png" alt="Opensource to Opportunities talk" class="talk-img" />
        <div class="play-overlay">
          <div class="play-btn">
            <svg viewBox="0 0 24 24" fill="currentColor" class="play-icon"><polygon points="5,3 19,12 5,21"/></svg>
          </div>
        </div>
      </div>
      <div class="talk-info">
        <span class="talk-tag">YouTube</span>
        <h3 class="talk-name">GSoC Alumni Meet 2023: Opensource to Opportunities</h3>
        <p class="talk-desc">
          How open source can be leveraged to land opportunities and grow as
          a software engineer in the tech industry.
        </p>
      </div>
    </a>
  </section>

  <!-- Recent Writing Section -->
  <section class="section reveal">
    <div class="section-header">
      <div class="section-label-group">
        <span class="section-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </span>
        <h2 class="section-label">Recent Writing</h2>
      </div>
      <a href="/blogs" class="section-action">
        All articles
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>

    <div class="articles-list">
      {
        blogs.map((blog: any, i: number) => (
          <a
            href={blog.canonical_url}
            target="_blank"
            rel="noopener noreferrer"
            class={`article-row reveal reveal-delay-${i + 1}`}
          >
            <div class="article-main">
              <h3 class="article-title">{blog.title}</h3>
              <p class="article-excerpt">{blog.description}</p>
            </div>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="article-arrow">
              <path d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </a>
        ))
      }
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section cta-section reveal">
    <div class="cta-panel">
      <div class="cta-glow" aria-hidden="true"></div>
      <div class="cta-content">
        <h2 class="cta-title">Let's build something together</h2>
        <p class="cta-text">
          I'm always open to discussing new projects, creative ideas, or opportunities to be part of something great.
        </p>
        <a href="mailto:sidmohanty11@gmail.com" class="cta-btn">
          <span>Get in touch</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Sections */
  .section {
    padding: 3.5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    position: relative;
  }

  .section::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 0;
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, rgba(99, 102, 241, 0.5), transparent);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.75rem;
  }

  .section-label-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: rgba(99, 102, 241, 0.1);
    color: #818cf8;
  }

  .section-icon svg {
    width: 14px;
    height: 14px;
    stroke-width: 2;
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #71717a;
  }

  .section-action {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    color: #52525b;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .section-action:hover {
    color: #818cf8;
  }

  .section-action svg {
    width: 14px;
    height: 14px;
    stroke-width: 2;
    transition: transform 0.2s ease;
  }

  .section-action:hover svg {
    transform: translateX(2px);
  }

  /* Glass panel */
  .glass-panel {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    backdrop-filter: blur(12px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  /* Timeline */
  .timeline-panel {
    padding: 0.5rem 1.25rem;
  }

  .timeline-group {
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .timeline-group:last-child {
    border-bottom: none;
  }

  .year-btn {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    background: none;
    border: none;
    cursor: pointer;
    color: #fafafa;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .year-btn:hover {
    color: #818cf8;
  }

  .chevron-icon {
    width: 16px;
    height: 16px;
    stroke-width: 2;
    color: #3f3f46;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .year-btn:hover .chevron-icon {
    color: #818cf8;
  }

  .year-btn.expanded .chevron-icon {
    transform: rotate(180deg);
  }

  .timeline-items {
    list-style: none;
    margin: 0;
    padding: 0 0 0.75rem 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  .timeline-items.collapsed {
    max-height: 0;
    opacity: 0;
    padding-bottom: 0;
  }

  .timeline-items.expanded {
    max-height: 500px;
    opacity: 1;
  }

  .timeline-entry {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.5rem 0;
    transition: padding-left 0.2s ease;
  }

  .timeline-entry:hover {
    padding-left: 0.25rem;
  }

  .entry-dot {
    width: 6px;
    height: 6px;
    background: #6366f1;
    border-radius: 50%;
    margin-top: 0.5rem;
    flex-shrink: 0;
    box-shadow: 0 0 6px rgba(99, 102, 241, 0.4);
    transition: box-shadow 0.2s ease;
  }

  .timeline-entry:hover .entry-dot {
    box-shadow: 0 0 12px rgba(99, 102, 241, 0.6);
  }

  .entry-text {
    font-size: 0.925rem;
    line-height: 1.6;
    color: #a1a1aa;
    transition: color 0.2s ease;
  }

  .timeline-entry:hover .entry-text {
    color: #d4d4d8;
  }

  /* Talk Card */
  .talk-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .talk-card {
      flex-direction: row;
      gap: 1.5rem;
      padding: 1.25rem;
    }
  }

  .talk-card:hover {
    border-color: rgba(99, 102, 241, 0.2);
    background: rgba(99, 102, 241, 0.03);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(99, 102, 241, 0.1);
    transform: translateY(-2px);
  }

  .talk-thumbnail {
    position: relative;
    flex-shrink: 0;
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 16/9;
    width: 100%;
  }

  @media (min-width: 640px) {
    .talk-thumbnail {
      width: 300px;
    }
  }

  .talk-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .talk-card:hover .talk-img {
    transform: scale(1.05);
  }

  .play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(to top, rgba(0,0,0,0.5), rgba(0,0,0,0.1));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .talk-card:hover .play-overlay {
    opacity: 1;
  }

  .play-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
  }

  .talk-card:hover .play-btn {
    background: rgba(255, 255, 255, 0.25);
    transform: scale(1.1);
  }

  .play-icon {
    width: 20px;
    height: 20px;
    color: #fff;
    margin-left: 2px;
  }

  .talk-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
  }

  .talk-tag {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #ef4444;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .talk-tag::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ef4444;
  }

  .talk-name {
    font-size: 1.15rem;
    font-weight: 600;
    color: #fafafa;
    line-height: 1.35;
    letter-spacing: -0.02em;
  }

  .talk-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #71717a;
    margin: 0;
  }

  /* Articles */
  .articles-list {
    display: flex;
    flex-direction: column;
  }

  .article-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 0.75rem;
    margin: 0 -0.75rem;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .article-row + .article-row {
    border-top: 1px solid rgba(255, 255, 255, 0.03);
  }

  .article-row:hover {
    background: rgba(255, 255, 255, 0.025);
    padding-left: 1.25rem;
  }

  .article-row:hover .article-title {
    color: #818cf8;
  }

  .article-row:hover .article-arrow {
    color: #818cf8;
    transform: translate(3px, -3px);
  }

  .article-main {
    flex: 1;
    min-width: 0;
  }

  .article-title {
    font-size: 1rem;
    font-weight: 500;
    color: #e4e4e7;
    margin-bottom: 0.3rem;
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  .article-excerpt {
    font-size: 0.85rem;
    color: #71717a;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-arrow {
    width: 20px;
    height: 20px;
    stroke-width: 2;
    color: #27272a;
    flex-shrink: 0;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* CTA */
  .cta-section {
    padding: 4rem 0 5rem;
    border-top: none;
  }

  .cta-section::before {
    display: none;
  }

  .cta-panel {
    position: relative;
    border: 1px solid rgba(99, 102, 241, 0.15);
    border-radius: 20px;
    padding: 3.5rem 2rem;
    text-align: center;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.04), rgba(139, 92, 246, 0.02), rgba(59, 130, 246, 0.03));
  }

  .cta-glow {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.12) 0%, transparent 70%);
    filter: blur(60px);
    pointer-events: none;
  }

  .cta-content {
    position: relative;
    z-index: 1;
    max-width: 440px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.035em;
    margin-bottom: 0.875rem;
    color: #fafafa;
    line-height: 1.15;
  }

  @media (min-width: 768px) {
    .cta-title {
      font-size: 2.5rem;
    }
  }

  .cta-text {
    font-size: 1rem;
    color: #71717a;
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    background: linear-gradient(135deg, #6366f1, #7c3aed);
    color: #fff;
    border-radius: 10px;
    font-size: 0.925rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(99, 102, 241, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .cta-btn svg {
    width: 16px;
    height: 16px;
    stroke-width: 2;
    transition: transform 0.2s ease;
  }

  .cta-btn:hover svg {
    transform: translate(2px, -2px);
  }
</style>

<script>
  function toggleYear(year: string) {
    const heading = document.querySelector(`[data-year="${year}"]`);
    const content = document.querySelector(`[data-year-content="${year}"]`);

    if (heading && content) {
      const isExpanded = heading.classList.contains("expanded");
      if (isExpanded) {
        heading.classList.replace("expanded", "collapsed");
        content.classList.replace("expanded", "collapsed");
      } else {
        heading.classList.replace("collapsed", "expanded");
        content.classList.replace("collapsed", "expanded");
      }
    }
  }

  (window as any).toggleYear = toggleYear;
</script>

<script>
  const contactForm = document.getElementById("contact-form");
  const contactFormBtn = document.getElementById("contactFormBtn");
  const emailRegex = /^[\w-\.]+@([\w-]+\.)+[\w-]{2,4}$/g;

  contactForm?.addEventListener("submit", function (e) {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    if (form.from_name.value.length < 3 || form.message.value.length < 10 || !emailRegex.test(form.reply_to.value)) {
      alert("Please fill the form correctly");
      return;
    }
    contactFormBtn?.setAttribute("disabled", "disabled");
    (window as any).emailjs
      .sendForm("service_hf1jiuc", "template_pg4422m", form, "aJgInfpLC2IuFXA9X")
      .then(() => { alert("Message sent successfully!"); contactFormBtn?.removeAttribute("disabled"); })
      .catch((err: any) => { console.log(err); contactFormBtn?.removeAttribute("disabled"); });
  });
</script>
