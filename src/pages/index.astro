---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";

const lifeUpdates = {
  "2025": [
    { id: 1, title: "Promoted to Software Engineer II at Builder.io" },
  ],
  "2024": [
    { id: 1, title: "Joined Builder.io as a Software Engineer" },
    { id: 2, title: "Google Summer of Code mentor 2024 with Rocket.Chat" },
  ],
  "2023": [
    { id: 9, title: "Got selected for an internship at my dream company - Builder.io" },
    { id: 1, title: "Linux Foundation Mentorship Program 2023 with The Open Mainframe Project" },
    { id: 5, title: "Contributed to Embedchain - an Open Source RAG framework" },
    { id: 2, title: "Google Summer of Code mentor 2023 with Rocket.Chat" },
  ],
  "2022": [
    { id: 3, title: "Google Summer of Code 2022 with Rocket.Chat" },
    { id: 2, title: "Selected as React.js Subject Matter Expert at Relevel" },
    { id: 1, title: "Software Engineer Intern at DragonfruitAI" },
  ],
};

let blogs = (await fetch(
  "https://dev.to/api/articles?username=sidmohanty11"
).then((res) => res.json())) as any[];
blogs = blogs.splice(0, 3);
---

<Layout title="Sidharth Mohanty" description="Software Engineer - Portfolio">
  <Hero />

  <section class="section" style="animation: fadeInUp 0.6s ease 0.1s both;">
    <div class="section-header">
      <h2 class="section-label">Timeline</h2>
      <a href="/experiences" class="section-action">
        View all
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>

    <div class="timeline">
      {
        Object.entries(lifeUpdates)
          .sort(([a], [b]) => parseInt(b) - parseInt(a))
          .map(([year, updates]) => (
            <div class="timeline-group">
              <button
                class={`year-btn ${year === "2025" ? "expanded" : "collapsed"}`}
                data-year={year}
                onclick={`toggleYear('${year}')`}
              >
                <span class="year-label">{year}</span>
                <svg class="chevron-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                  <polyline points="6,9 12,15 18,9"></polyline>
                </svg>
              </button>
              <ul
                class={`timeline-items ${year === "2025" ? "expanded" : "collapsed"}`}
                data-year-content={year}
              >
                {updates.map((u) => (
                  <li class="timeline-entry">
                    <span class="entry-dot"></span>
                    <span class="entry-text">{u.title}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
      }
    </div>
  </section>

  <section class="section" style="animation: fadeInUp 0.6s ease 0.2s both;">
    <div class="section-header">
      <h2 class="section-label">Featured Talk</h2>
      <a
        href="https://www.youtube.com/playlist?list=PL6p5XNtolyav0udwal2UzwP4vqTPXZUDz"
        target="_blank"
        rel="noopener noreferrer"
        class="section-action"
      >
        All talks
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>

    <a
      href="https://www.youtube.com/watch?v=ZDlelRrL-8g&list=PL6p5XNtolyav0udwal2UzwP4vqTPXZUDz"
      target="_blank"
      rel="noopener noreferrer"
      class="talk-card"
    >
      <div class="talk-thumbnail">
        <img
          src="/assets/rc1.png"
          alt="Opensource to Opportunities talk"
          class="talk-img"
        />
        <div class="play-overlay">
          <svg viewBox="0 0 24 24" fill="currentColor" class="play-icon">
            <polygon points="5,3 19,12 5,21"></polygon>
          </svg>
        </div>
      </div>
      <div class="talk-info">
        <h3 class="talk-name">GSoC Alumni Meet 2023: Opensource to Opportunities</h3>
        <p class="talk-desc">
          How open source can be leveraged to land opportunities and grow as
          a software engineer in the tech industry.
        </p>
      </div>
    </a>
  </section>

  <section class="section" style="animation: fadeInUp 0.6s ease 0.3s both;">
    <div class="section-header">
      <h2 class="section-label">Recent Writing</h2>
      <a href="/blogs" class="section-action">
        All articles
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>

    <div class="articles-list">
      {
        blogs.map((blog: any) => (
          <a
            href={blog.canonical_url}
            target="_blank"
            rel="noopener noreferrer"
            class="article-row"
          >
            <div class="article-main">
              <h3 class="article-title">{blog.title}</h3>
              <p class="article-excerpt">{blog.description}</p>
            </div>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="article-arrow">
              <path d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section cta-section" style="animation: fadeInUp 0.6s ease 0.4s both;">
    <div class="cta-content">
      <h2 class="cta-title">Let's connect</h2>
      <p class="cta-text">
        I'm always open to discussing new projects, creative ideas, or opportunities to be part of something great.
      </p>
      <a href="mailto:sidmohanty11@gmail.com" class="cta-btn">
        Get in touch
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M7 17L17 7M17 7H7M17 7V17"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  .section {
    padding: 3rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.75rem;
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #71717a;
  }

  .section-action {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    color: #a1a1aa;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .section-action:hover {
    color: #fafafa;
  }

  .section-action svg {
    width: 14px;
    height: 14px;
    stroke-width: 2;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-group {
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .timeline-group:last-child {
    border-bottom: none;
  }

  .year-btn {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.875rem 0;
    background: none;
    border: none;
    cursor: pointer;
    color: #fafafa;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .year-btn:hover {
    color: #818cf8;
  }

  .chevron-icon {
    width: 16px;
    height: 16px;
    stroke-width: 2;
    color: #52525b;
    transition: transform 0.25s ease;
  }

  .year-btn.expanded .chevron-icon {
    transform: rotate(180deg);
  }

  .timeline-items {
    list-style: none;
    margin: 0;
    padding: 0 0 0.75rem 0;
    overflow: hidden;
    transition: max-height 0.3s ease, opacity 0.3s ease;
  }

  .timeline-items.collapsed {
    max-height: 0;
    opacity: 0;
    padding-bottom: 0;
  }

  .timeline-items.expanded {
    max-height: 500px;
    opacity: 1;
  }

  .timeline-entry {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.5rem 0;
  }

  .entry-dot {
    width: 5px;
    height: 5px;
    background: #6366f1;
    border-radius: 50%;
    margin-top: 0.55rem;
    flex-shrink: 0;
  }

  .entry-text {
    font-size: 0.925rem;
    line-height: 1.6;
    color: #a1a1aa;
  }

  /* Talk Card */
  .talk-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s ease;
    background: rgba(255, 255, 255, 0.02);
  }

  @media (min-width: 640px) {
    .talk-card {
      flex-direction: row;
      gap: 1.5rem;
    }
  }

  .talk-card:hover {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.03);
  }

  .talk-thumbnail {
    position: relative;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 16/9;
    width: 100%;
  }

  @media (min-width: 640px) {
    .talk-thumbnail {
      width: 280px;
    }
  }

  .talk-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .talk-card:hover .talk-img {
    transform: scale(1.03);
  }

  .play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.3);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .talk-card:hover .play-overlay {
    opacity: 1;
  }

  .play-icon {
    width: 36px;
    height: 36px;
    color: #fff;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.3));
  }

  .talk-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
  }

  .talk-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: #fafafa;
    line-height: 1.35;
    letter-spacing: -0.02em;
  }

  .talk-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #71717a;
    margin: 0;
  }

  /* Articles */
  .articles-list {
    display: flex;
    flex-direction: column;
  }

  .article-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .article-row:last-child {
    border-bottom: none;
  }

  .article-row:hover {
    padding-left: 0.5rem;
  }

  .article-row:hover .article-title {
    color: #818cf8;
  }

  .article-row:hover .article-arrow {
    color: #818cf8;
    transform: translate(2px, -2px);
  }

  .article-main {
    flex: 1;
    min-width: 0;
  }

  .article-title {
    font-size: 1rem;
    font-weight: 500;
    color: #e4e4e7;
    margin-bottom: 0.25rem;
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  .article-excerpt {
    font-size: 0.85rem;
    color: #52525b;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-arrow {
    width: 18px;
    height: 18px;
    stroke-width: 2;
    color: #3f3f46;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  /* CTA */
  .cta-section {
    text-align: center;
    padding: 5rem 0;
  }

  .cta-content {
    max-width: 420px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
    color: #fafafa;
  }

  .cta-text {
    font-size: 0.95rem;
    color: #71717a;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: #6366f1;
    color: #fff;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .cta-btn:hover {
    background: #4f46e5;
    transform: translateY(-1px);
  }

  .cta-btn svg {
    width: 16px;
    height: 16px;
    stroke-width: 2;
  }
</style>

<script>
  function toggleYear(year: string) {
    const heading = document.querySelector(`[data-year="${year}"]`);
    const content = document.querySelector(`[data-year-content="${year}"]`);

    if (heading && content) {
      const isExpanded = heading.classList.contains("expanded");

      if (isExpanded) {
        heading.classList.replace("expanded", "collapsed");
        content.classList.replace("expanded", "collapsed");
      } else {
        heading.classList.replace("collapsed", "expanded");
        content.classList.replace("collapsed", "expanded");
      }
    }
  }

  (window as any).toggleYear = toggleYear;
</script>

<script>
  const contactForm = document.getElementById("contact-form");
  const contactFormBtn = document.getElementById("contactFormBtn");

  const emailRegex = /^[\w-\.]+@([\w-]+\.)+[\w-]{2,4}$/g;

  contactForm?.addEventListener("submit", function (e) {
    e.preventDefault();
    const form = e.target as HTMLFormElement;

    if (
      form.from_name.value.length < 3 ||
      form.message.value.length < 10 ||
      !emailRegex.test(form.reply_to.value)
    ) {
      alert("Please fill the form correctly");
      return;
    }

    contactFormBtn?.setAttribute("disabled", "disabled");

    (window as any).emailjs
      .sendForm(
        "service_hf1jiuc",
        "template_pg4422m",
        form,
        "aJgInfpLC2IuFXA9X"
      )
      .then(() => {
        alert("Message sent successfully!");
        contactFormBtn?.removeAttribute("disabled");
      })
      .catch((err: any) => {
        console.log(err);
        contactFormBtn?.removeAttribute("disabled");
      });
  });
</script>
