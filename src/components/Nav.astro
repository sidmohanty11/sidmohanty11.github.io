---
const navElements = [
  { id: 1, name: "Home", path: "/" },
  { id: 2, name: "Story", path: "/story" },
  { id: 3, name: "Blogs", path: "/blogs" },
  { id: 4, name: "Experience", path: "/experiences" },
  { id: 5, name: "Projects", path: "/projects" },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-text">sid.</span>
    </a>

    <nav class="desktop-nav">
      {
        navElements.map((el) => (
          <a href={el.path} class="nav-link">
            {el.name}
          </a>
        ))
      }
      <a
        target="_blank"
        rel="noopener noreferrer"
        href="https://drive.google.com/file/d/1EoFN--jq4xlQJ53tqIHTBhZa87qdNUUG/view"
        class="resume-btn"
      >
        Resume
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="resume-icon">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          <polyline points="15,3 21,3 21,9"></polyline>
          <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
      </a>
    </nav>

    <button type="button" class="mobile-menu-btn" id="navigationBtn" aria-label="Open menu">
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
    </button>
  </div>

  <div class="mobile-overlay hidden" id="mobileNav">
    <div class="mobile-overlay-inner">
      <div class="mobile-header">
        <a href="/" class="logo">
          <span class="logo-text">sid.</span>
        </a>
        <button class="mobile-close-btn" id="closeNavBtn" aria-label="Close menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <nav class="mobile-nav-links">
        {
          navElements.map((el) => (
            <a href={el.path} class="mobile-link">
              {el.name}
            </a>
          ))
        }
        <a
          target="_blank"
          rel="noopener noreferrer"
          href="https://drive.google.com/file/d/1EoFN--jq4xlQJ53tqIHTBhZa87qdNUUG/view"
          class="mobile-link"
        >
          Resume
        </a>
      </nav>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 64px;
  }

  @media (min-width: 768px) {
    .header-inner {
      padding: 0 2.5rem;
    }
  }

  .logo {
    text-decoration: none;
  }

  .logo-text {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.25rem;
    font-weight: 500;
    color: #fafafa;
    letter-spacing: -0.02em;
  }

  .desktop-nav {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .desktop-nav {
      display: flex;
    }
  }

  .nav-link {
    color: #a1a1aa;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 400;
    transition: color 0.2s ease;
    letter-spacing: 0;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #fafafa;
  }

  .resume-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #fafafa;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .resume-btn:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.25);
  }

  .resume-icon {
    width: 0.875rem;
    height: 0.875rem;
    stroke-width: 2;
  }

  .mobile-menu-btn {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
  }

  @media (min-width: 768px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  .menu-bar {
    display: block;
    width: 20px;
    height: 2px;
    background: #fafafa;
    border-radius: 1px;
    transition: all 0.2s ease;
  }

  .mobile-menu-btn:hover .menu-bar {
    background: #a1a1aa;
  }

  .mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 10, 0.98);
    backdrop-filter: blur(20px);
    z-index: 100;
    animation: fadeIn 0.2s ease;
  }

  .mobile-overlay.hidden {
    display: none;
  }

  .mobile-overlay-inner {
    padding: 0 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .mobile-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 64px;
  }

  .mobile-close-btn {
    background: none;
    border: none;
    color: #a1a1aa;
    cursor: pointer;
    padding: 6px;
    transition: color 0.2s ease;
  }

  .mobile-close-btn:hover {
    color: #fafafa;
  }

  .mobile-close-btn svg {
    width: 24px;
    height: 24px;
    stroke-width: 1.5;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 2rem;
  }

  .mobile-link {
    color: #a1a1aa;
    text-decoration: none;
    font-size: 2rem;
    font-weight: 300;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: color 0.2s ease;
    letter-spacing: -0.02em;
  }

  .mobile-link:hover,
  .mobile-link.active {
    color: #fafafa;
  }
</style>

<script>
  const mobileNav = document.querySelector("#mobileNav");
  const navigationBtn = document.querySelector("#navigationBtn");
  const closeNavBtn = document.querySelector("#closeNavBtn");

  const pathname = window.location.pathname;

  const navLinks = document.querySelectorAll(".nav-link, .mobile-link");
  navLinks.forEach((link) => {
    const href = link.getAttribute("href");
    if (href === pathname || `${href}/` === pathname) {
      link.classList.add("active");
    }
  });

  document.addEventListener("click", (e) => {
    if (
      e.target !== mobileNav &&
      e.target !== navigationBtn &&
      !mobileNav?.contains(e.target as Node) &&
      !navigationBtn?.contains(e.target as Node)
    ) {
      mobileNav?.classList.add("hidden");
    }
  });

  closeNavBtn?.addEventListener("click", () => {
    mobileNav?.classList.add("hidden");
  });

  navigationBtn?.addEventListener("click", () => {
    mobileNav?.classList.remove("hidden");
  });
</script>
