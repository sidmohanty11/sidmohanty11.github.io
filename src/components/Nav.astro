---
const navElements = [
  { id: 1, name: "Home", path: "/" },
  { id: 2, name: "Story", path: "/story" },
  { id: 3, name: "Blogs", path: "/blogs" },
  { id: 4, name: "Experience", path: "/experiences" },
  { id: 5, name: "Projects", path: "/projects" },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-text">sid<span class="logo-dot">.</span></span>
    </a>

    <nav class="desktop-nav">
      {
        navElements.map((el) => (
          <a href={el.path} class="nav-link">
            {el.name}
          </a>
        ))
      }
      <a
        target="_blank"
        rel="noopener noreferrer"
        href="https://drive.google.com/file/d/1EoFN--jq4xlQJ53tqIHTBhZa87qdNUUG/view"
        class="resume-btn"
      >
        Resume
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="resume-icon">
          <path d="M7 17L17 7M17 7H7M17 7V17"/>
        </svg>
      </a>
    </nav>

    <button type="button" class="mobile-menu-btn" id="navigationBtn" aria-label="Open menu">
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
    </button>
  </div>

  <div class="mobile-overlay hidden" id="mobileNav">
    <div class="mobile-overlay-inner">
      <div class="mobile-header">
        <a href="/" class="logo">
          <span class="logo-text">sid<span class="logo-dot">.</span></span>
        </a>
        <button class="mobile-close-btn" id="closeNavBtn" aria-label="Close menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <nav class="mobile-nav-links">
        {
          navElements.map((el, i) => (
            <a href={el.path} class="mobile-link" style={`animation-delay: ${i * 0.05}s`}>
              <span class="mobile-link-num">{String(i + 1).padStart(2, "0")}</span>
              {el.name}
            </a>
          ))
        }
        <a
          target="_blank"
          rel="noopener noreferrer"
          href="https://drive.google.com/file/d/1EoFN--jq4xlQJ53tqIHTBhZa87qdNUUG/view"
          class="mobile-link"
          style="animation-delay: 0.25s"
        >
          <span class="mobile-link-num">06</span>
          Resume
        </a>
      </nav>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(5, 5, 5, 0.7);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 1px 12px rgba(0, 0, 0, 0.4);
  }

  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 60px;
  }

  @media (min-width: 768px) {
    .header-inner {
      padding: 0 2.5rem;
    }
  }

  .logo {
    text-decoration: none;
  }

  .logo-text {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.25rem;
    font-weight: 500;
    color: #fafafa;
    letter-spacing: -0.02em;
  }

  .logo-dot {
    color: #6366f1;
  }

  .desktop-nav {
    display: none;
    align-items: center;
    gap: 0.375rem;
  }

  @media (min-width: 768px) {
    .desktop-nav {
      display: flex;
    }
  }

  .nav-link {
    color: #71717a;
    text-decoration: none;
    font-size: 0.825rem;
    font-weight: 500;
    transition: all 0.2s ease;
    letter-spacing: 0;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    position: relative;
  }

  .nav-link:hover {
    color: #d4d4d8;
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-link.active {
    color: #fafafa;
    background: rgba(255, 255, 255, 0.06);
  }

  .nav-link.active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 2px;
    background: #6366f1;
    border-radius: 1px;
  }

  .resume-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: #e4e4e7;
    font-size: 0.825rem;
    font-weight: 500;
    padding: 0.4rem 0.875rem;
    border: 1px solid rgba(99, 102, 241, 0.3);
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.25s ease;
    margin-left: 0.5rem;
    background: rgba(99, 102, 241, 0.06);
  }

  .resume-btn:hover {
    background: rgba(99, 102, 241, 0.12);
    border-color: rgba(99, 102, 241, 0.5);
    box-shadow: 0 0 16px rgba(99, 102, 241, 0.1);
  }

  .resume-icon {
    width: 0.8rem;
    height: 0.8rem;
    stroke-width: 2;
  }

  .mobile-menu-btn {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: 6px;
    transition: background 0.2s ease;
  }

  .mobile-menu-btn:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  @media (min-width: 768px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  .menu-bar {
    display: block;
    width: 18px;
    height: 1.5px;
    background: #a1a1aa;
    border-radius: 1px;
    transition: all 0.2s ease;
  }

  .mobile-menu-btn:hover .menu-bar {
    background: #fafafa;
  }

  /* Mobile overlay */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(5, 5, 5, 0.97);
    backdrop-filter: blur(24px);
    z-index: 100;
  }

  .mobile-overlay.hidden {
    display: none;
  }

  .mobile-overlay-inner {
    padding: 0 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .mobile-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 60px;
  }

  .mobile-close-btn {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #71717a;
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mobile-close-btn:hover {
    color: #fafafa;
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.04);
  }

  .mobile-close-btn svg {
    width: 20px;
    height: 20px;
    stroke-width: 1.5;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    margin-top: 3rem;
  }

  .mobile-link {
    color: #52525b;
    text-decoration: none;
    font-size: 2.25rem;
    font-weight: 300;
    padding: 0.875rem 0;
    transition: all 0.3s ease;
    letter-spacing: -0.03em;
    display: flex;
    align-items: baseline;
    gap: 1rem;
    animation: fadeInUp 0.4s ease both;
  }

  .mobile-link:hover,
  .mobile-link.active {
    color: #fafafa;
    padding-left: 0.5rem;
  }

  .mobile-link.active {
    color: #818cf8;
  }

  .mobile-link-num {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: #3f3f46;
    letter-spacing: 0;
  }

  .mobile-link:hover .mobile-link-num,
  .mobile-link.active .mobile-link-num {
    color: #6366f1;
  }
</style>

<script>
  const mobileNav = document.querySelector("#mobileNav");
  const navigationBtn = document.querySelector("#navigationBtn");
  const closeNavBtn = document.querySelector("#closeNavBtn");

  const pathname = window.location.pathname;

  const navLinks = document.querySelectorAll(".nav-link, .mobile-link");
  navLinks.forEach((link) => {
    const href = link.getAttribute("href");
    if (href === pathname || `${href}/` === pathname) {
      link.classList.add("active");
    }
  });

  document.addEventListener("click", (e) => {
    if (
      e.target !== mobileNav &&
      e.target !== navigationBtn &&
      !mobileNav?.contains(e.target as Node) &&
      !navigationBtn?.contains(e.target as Node)
    ) {
      mobileNav?.classList.add("hidden");
    }
  });

  closeNavBtn?.addEventListener("click", () => {
    mobileNav?.classList.add("hidden");
  });

  navigationBtn?.addEventListener("click", () => {
    mobileNav?.classList.remove("hidden");
  });
</script>
