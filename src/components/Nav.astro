---
const navElements = [
  { id: 1, name: "Home", path: "/" },
  { id: 2, name: "Story", path: "/story" },
  { id: 3, name: "Blogs", path: "/blogs" },
  { id: 4, name: "Experience", path: "/experiences" },
  { id: 5, name: "Projects", path: "/projects" },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-text">sid<span class="logo-dot">.</span></span>
    </a>

    <nav class="desktop-nav">
      {
        navElements.map((el) => (
          <a href={el.path} class="nav-link">
            {el.name}
          </a>
        ))
      }
      <div class="nav-actions">
        <a
          target="_blank"
          rel="noopener noreferrer"
          href="https://drive.google.com/file/d/1EoFN--jq4xlQJ53tqIHTBhZa87qdNUUG/view"
          class="nav-action-link"
        >
          Resume
        </a>
        <a href="mailto:sidmohanty11@gmail.com" class="nav-action-link">
          Contact
        </a>
        <a href="https://github.com/sidmohanty11" target="_blank" rel="noopener noreferrer" class="nav-icon-link" aria-label="GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <a href="https://twitter.com/sidmohanty11" target="_blank" rel="noopener noreferrer" class="nav-icon-link" aria-label="Twitter">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </nav>

    <button type="button" class="mobile-menu-btn" id="navigationBtn" aria-label="Open menu">
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
    </button>
  </div>

  <div class="mobile-overlay hidden" id="mobileNav">
    <div class="mobile-overlay-inner">
      <div class="mobile-header">
        <a href="/" class="logo">
          <span class="logo-text">sid<span class="logo-dot">.</span></span>
        </a>
        <button class="mobile-close-btn" id="closeNavBtn" aria-label="Close menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <nav class="mobile-nav-links">
        {
          navElements.map((el, i) => (
            <a href={el.path} class="mobile-link" style={`animation-delay: ${i * 0.05}s`}>
              <span class="mobile-link-num">{String(i + 1).padStart(2, "0")}</span>
              {el.name}
            </a>
          ))
        }
        <a
          target="_blank"
          rel="noopener noreferrer"
          href="https://drive.google.com/file/d/1EoFN--jq4xlQJ53tqIHTBhZa87qdNUUG/view"
          class="mobile-link"
          style="animation-delay: 0.25s"
        >
          <span class="mobile-link-num">06</span>
          Resume
        </a>
      </nav>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(5, 5, 5, 0.7);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 1px 12px rgba(0, 0, 0, 0.4);
  }

  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 60px;
  }

  @media (min-width: 768px) {
    .header-inner {
      padding: 0 2.5rem;
    }
  }

  .logo {
    text-decoration: none;
  }

  .logo-text {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.25rem;
    font-weight: 500;
    color: #fafafa;
    letter-spacing: -0.02em;
  }

  .logo-dot {
    color: #6366f1;
  }

  .desktop-nav {
    display: none;
    align-items: center;
    gap: 0.375rem;
  }

  @media (min-width: 768px) {
    .desktop-nav {
      display: flex;
    }
  }

  .nav-link {
    color: #71717a;
    text-decoration: none;
    font-size: 0.825rem;
    font-weight: 500;
    transition: all 0.2s ease;
    letter-spacing: 0;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    position: relative;
  }

  .nav-link:hover {
    color: #d4d4d8;
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-link.active {
    color: #fafafa;
    background: rgba(255, 255, 255, 0.06);
  }

  .nav-link.active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 2px;
    background: #6366f1;
    border-radius: 1px;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    margin-left: 0.75rem;
    padding-left: 0.75rem;
    border-left: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav-action-link {
    color: #a1a1aa;
    font-size: 0.825rem;
    font-weight: 500;
    padding: 0.4rem 0.625rem;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .nav-action-link:hover {
    color: #fafafa;
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: #52525b;
    border-radius: 6px;
    transition: all 0.2s ease;
  }

  .nav-icon-link:hover {
    color: #a1a1aa;
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-icon-link svg {
    width: 15px;
    height: 15px;
  }

  .mobile-menu-btn {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: 6px;
    transition: background 0.2s ease;
  }

  .mobile-menu-btn:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  @media (min-width: 768px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  .menu-bar {
    display: block;
    width: 18px;
    height: 1.5px;
    background: #a1a1aa;
    border-radius: 1px;
    transition: all 0.2s ease;
  }

  .mobile-menu-btn:hover .menu-bar {
    background: #fafafa;
  }

  /* Mobile overlay */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(5, 5, 5, 0.97);
    backdrop-filter: blur(24px);
    z-index: 100;
  }

  .mobile-overlay.hidden {
    display: none;
  }

  .mobile-overlay-inner {
    padding: 0 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .mobile-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 60px;
  }

  .mobile-close-btn {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #71717a;
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mobile-close-btn:hover {
    color: #fafafa;
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.04);
  }

  .mobile-close-btn svg {
    width: 20px;
    height: 20px;
    stroke-width: 1.5;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    margin-top: 3rem;
  }

  .mobile-link {
    color: #52525b;
    text-decoration: none;
    font-size: 2.25rem;
    font-weight: 300;
    padding: 0.875rem 0;
    transition: all 0.3s ease;
    letter-spacing: -0.03em;
    display: flex;
    align-items: baseline;
    gap: 1rem;
    animation: fadeInUp 0.4s ease both;
  }

  .mobile-link:hover,
  .mobile-link.active {
    color: #fafafa;
    padding-left: 0.5rem;
  }

  .mobile-link.active {
    color: #818cf8;
  }

  .mobile-link-num {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: #3f3f46;
    letter-spacing: 0;
  }

  .mobile-link:hover .mobile-link-num,
  .mobile-link.active .mobile-link-num {
    color: #6366f1;
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    var mobileNav = document.getElementById("mobileNav");
    var navigationBtn = document.getElementById("navigationBtn");
    var closeNavBtn = document.getElementById("closeNavBtn");

    var pathname = window.location.pathname;
    var navLinks = document.querySelectorAll(".nav-link, .mobile-link");
    navLinks.forEach(function (link) {
      var href = link.getAttribute("href");
      if (href === pathname || href + "/" === pathname) {
        link.classList.add("active");
      }
    });

    if (navigationBtn) {
      navigationBtn.addEventListener("click", function (e) {
        e.stopPropagation();
        if (mobileNav) mobileNav.classList.remove("hidden");
      });
    }

    if (closeNavBtn) {
      closeNavBtn.addEventListener("click", function (e) {
        e.stopPropagation();
        if (mobileNav) mobileNav.classList.add("hidden");
      });
    }

    // Close on overlay background click (not inner content)
    if (mobileNav) {
      mobileNav.addEventListener("click", function (e) {
        if (e.target === mobileNav) {
          mobileNav.classList.add("hidden");
        }
      });
    }

    // Close on link click
    var mobileLinks = document.querySelectorAll(".mobile-link");
    mobileLinks.forEach(function (link) {
      link.addEventListener("click", function () {
        if (mobileNav) mobileNav.classList.add("hidden");
      });
    });
  });
</script>
