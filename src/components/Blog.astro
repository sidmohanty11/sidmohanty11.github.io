---
export interface Props {
  blog: {
    id: string | number;
    title: string;
    description: string;
    tag_list: string[];
    public_reactions_count: number;
    reading_time_minutes: number;
    canonical_url: string;
    published_at: string;
  };
  index?: number;
}

const { blog, index = 0 } = Astro.props;

const publishedDate = new Date(blog.published_at || Date.now());
const formattedDate = publishedDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="blog-card">
  <a
    href={blog.canonical_url}
    target="_blank"
    rel="noopener noreferrer"
    class="card-link"
  >
    <div class="card-meta">
      <time class="card-date">{formattedDate}</time>
      <span class="card-reading">{blog.reading_time_minutes} min read</span>
    </div>

    <h3 class="card-title">{blog.title}</h3>

    <p class="card-desc">{blog.description}</p>

    {
      blog.tag_list && blog.tag_list.length > 0 && (
        <div class="card-tags">
          {blog.tag_list.slice(0, 3).map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )
    }

    <div class="card-footer">
      <div class="reactions">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="reaction-icon">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
        <span>{blog.public_reactions_count}</span>
      </div>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="arrow-icon">
        <path d="M7 17L17 7M17 7H7M17 7V17"/>
      </svg>
    </div>
  </a>
</article>

<style>
  .blog-card {
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.02);
    transition: all 0.25s ease;
    height: 100%;
  }

  .blog-card:hover {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.03);
    transform: translateY(-2px);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
  }

  .card-date {
    font-size: 0.75rem;
    color: #52525b;
    font-weight: 500;
  }

  .card-reading {
    font-size: 0.75rem;
    color: #52525b;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: #e4e4e7;
    line-height: 1.4;
    margin-bottom: 0.625rem;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .blog-card:hover .card-title {
    color: #818cf8;
  }

  .card-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #71717a;
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .tag {
    font-size: 0.7rem;
    color: #6366f1;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    margin-top: auto;
  }

  .reactions {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8rem;
    color: #52525b;
  }

  .reaction-icon {
    width: 14px;
    height: 14px;
    stroke-width: 2;
  }

  .arrow-icon {
    width: 16px;
    height: 16px;
    stroke-width: 2;
    color: #3f3f46;
    transition: all 0.2s ease;
  }

  .blog-card:hover .arrow-icon {
    color: #818cf8;
    transform: translate(2px, -2px);
  }
</style>
