<style>
  .hero {
    padding: 6rem 0 4rem;
    animation: fadeInUp 0.6s ease both;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 8rem 0 6rem;
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column-reverse;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero-content {
      flex-direction: row;
      justify-content: space-between;
      gap: 4rem;
      align-items: center;
    }
  }

  .hero-intro {
    flex: 1;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.875rem;
    background: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .status-text {
    font-size: 0.8rem;
    color: #86efac;
    font-weight: 500;
    letter-spacing: 0;
  }

  .hero-name {
    font-size: 3.25rem;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: #fafafa;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .hero-name {
      font-size: 4.5rem;
    }
  }

  .name-accent {
    background: linear-gradient(135deg, #818cf8, #6366f1, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-bio {
    font-size: 1.05rem;
    line-height: 1.7;
    color: #a1a1aa;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .social-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.875rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: #a1a1aa;
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .social-pill:hover {
    color: #fafafa;
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.04);
  }

  .social-pill svg {
    width: 1rem;
    height: 1rem;
  }

  .hero-visual {
    flex-shrink: 0;
  }

  .photo-wrapper {
    position: relative;
    width: 180px;
    height: 180px;
  }

  @media (min-width: 768px) {
    .photo-wrapper {
      width: 260px;
      height: 260px;
    }
  }

  .profile-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.08);
    position: relative;
    z-index: 1;
    transition: border-color 0.3s ease;
  }

  .profile-photo:hover {
    border-color: rgba(99, 102, 241, 0.4);
  }

  .photo-glow {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 70%);
    z-index: 0;
    filter: blur(20px);
  }
</style>
