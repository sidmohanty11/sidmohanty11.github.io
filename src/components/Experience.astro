---
export interface Props {
  experience: {
    id: string | number;
    title: string;
    company: string;
    description: string;
    span: string;
    skills?: string[];
  };
  index?: number;
}

const { experience, index = 0 } = Astro.props;
---

<article class="exp-card">
  <div class="exp-left">
    <time class="exp-period">{experience.span}</time>
  </div>
  <div class="exp-content">
    <div class="exp-header">
      <h3 class="exp-company" set:html={experience.company} />
      <p class="exp-role">{experience.title}</p>
    </div>
    <p class="exp-description" set:html={experience.description} />
    {
      experience.skills && experience.skills.length > 0 && (
        <div class="exp-skills">
          {experience.skills.map((skill) => (
            <span class="skill">{skill}</span>
          ))}
        </div>
      )
    }
  </div>
</article>

<style>
  .exp-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem 0 1.5rem 1.5rem;
    border-left: 1px solid rgba(255, 255, 255, 0.06);
    margin-left: 0;
    position: relative;
    transition: border-color 0.2s ease;
  }

  .exp-card:hover {
    border-left-color: rgba(99, 102, 241, 0.4);
  }

  .exp-card::before {
    content: "";
    position: absolute;
    left: -3px;
    top: 1.75rem;
    width: 5px;
    height: 5px;
    background: #3f3f46;
    border-radius: 50%;
    transition: background 0.2s ease;
  }

  .exp-card:hover::before {
    background: #6366f1;
  }

  @media (min-width: 640px) {
    .exp-card {
      flex-direction: row;
      gap: 2rem;
    }
  }

  .exp-left {
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .exp-left {
      width: 140px;
    }
  }

  .exp-period {
    font-size: 0.8rem;
    color: #52525b;
    font-weight: 500;
    white-space: nowrap;
    letter-spacing: 0;
  }

  .exp-content {
    flex: 1;
    min-width: 0;
  }

  .exp-header {
    margin-bottom: 0.625rem;
  }

  .exp-company {
    font-size: 1rem;
    font-weight: 600;
    color: #e4e4e7;
    margin-bottom: 0.125rem;
    letter-spacing: -0.01em;
  }

  :global(.exp-company a) {
    color: #e4e4e7 !important;
    text-decoration: none !important;
    transition: color 0.2s ease !important;
  }

  :global(.exp-company a:hover) {
    color: #818cf8 !important;
  }

  .exp-role {
    font-size: 0.85rem;
    color: #6366f1;
    font-weight: 500;
    margin: 0;
  }

  .exp-description {
    font-size: 0.9rem;
    line-height: 1.65;
    color: #71717a;
    margin: 0 0 0.75rem;
  }

  .exp-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .skill {
    font-size: 0.7rem;
    font-weight: 500;
    color: #52525b;
    padding: 0.25rem 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 4px;
    letter-spacing: 0.02em;
    transition: all 0.2s ease;
  }

  .skill:hover {
    color: #a1a1aa;
    border-color: rgba(255, 255, 255, 0.12);
  }
</style>
