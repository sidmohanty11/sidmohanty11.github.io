<style>
  .site-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 2.5rem 0 2rem;
    margin-top: 2rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  @media (max-width: 480px) {
    .footer-top {
      flex-direction: column;
      gap: 1.25rem;
    }
  }

  .footer-logo {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.1rem;
    font-weight: 500;
    color: #52525b;
    letter-spacing: -0.02em;
  }

  .footer-socials {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .footer-socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: #52525b;
    border-radius: 6px;
    transition: all 0.2s ease;
  }

  .footer-socials a:hover {
    color: #a1a1aa;
    background: rgba(255, 255, 255, 0.04);
  }

  .footer-socials svg {
    width: 16px;
    height: 16px;
    stroke-width: 1.5;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    padding-top: 1.5rem;
  }

  .copyright {
    font-size: 0.8rem;
    color: #3f3f46;
    margin: 0;
    text-align: center;
  }
</style>
