---
export interface Props {
  project: {
    id: string | number;
    name: string;
    description: string;
    github_link: string;
    live_link?: string;
    imgUrl: string;
    category?: string;
    year?: string;
  };
  index?: number;
}

const { project, index = 0 } = Astro.props;
---

<article class="mobile-card">
  <div class="phone-frame">
    <div class="phone-notch"></div>
    <div class="phone-screen">
      <img src={project.imgUrl} alt={project.name} class="screen-img" loading="lazy" />
    </div>
  </div>
  <div class="card-body">
    <div class="card-meta">
      {project.category && <span class="card-category">{project.category}</span>}
      {project.year && <span class="card-year">{project.year}</span>}
    </div>
    <h3 class="card-name">{project.name}</h3>
    <p class="card-desc">{project.description}</p>
    <div class="card-actions">
      {project.github_link && (
        <a href={project.github_link} target="_blank" rel="noopener noreferrer" class="action-link">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Code
        </a>
      )}
      {project.live_link && (
        <a href={project.live_link} target="_blank" rel="noopener noreferrer" class="action-link action-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7,10 12,15 17,10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .mobile-card {
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.02);
    padding: 1.5rem;
    transition: all 0.25s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }

  .mobile-card:hover {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.03);
    transform: translateY(-2px);
  }

  .phone-frame {
    background: #18181b;
    border-radius: 20px;
    padding: 0.75rem 0.5rem;
    width: 160px;
    margin-bottom: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .phone-notch {
    width: 40px;
    height: 3px;
    background: #27272a;
    border-radius: 2px;
    margin: 0 auto 0.5rem;
  }

  .phone-screen {
    border-radius: 12px;
    overflow: hidden;
    height: 220px;
    background: #09090b;
  }

  .screen-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
    transition: all 0.3s ease;
  }

  .mobile-card:hover .screen-img {
    opacity: 1;
    transform: scale(1.03);
  }

  .card-body {
    text-align: center;
    display: flex;
    flex-direction: column;
    flex: 1;
    width: 100%;
  }

  .card-meta {
    display: flex;
    justify-content: center;
    gap: 0.625rem;
    margin-bottom: 0.5rem;
  }

  .card-category {
    font-size: 0.7rem;
    font-weight: 500;
    color: #6366f1;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-year {
    font-size: 0.7rem;
    color: #52525b;
    font-weight: 500;
  }

  .card-name {
    font-size: 1rem;
    font-weight: 600;
    color: #e4e4e7;
    margin-bottom: 0.375rem;
    letter-spacing: -0.01em;
  }

  .card-desc {
    font-size: 0.825rem;
    line-height: 1.5;
    color: #71717a;
    margin: 0 0 1rem;
    flex: 1;
  }

  .card-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-top: auto;
  }

  .action-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    color: #a1a1aa;
    font-size: 0.75rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .action-link:hover {
    color: #fafafa;
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.04);
  }

  .action-link svg {
    width: 14px;
    height: 14px;
    stroke-width: 2;
  }

  .action-primary {
    background: rgba(99, 102, 241, 0.1);
    border-color: rgba(99, 102, 241, 0.2);
    color: #818cf8;
  }

  .action-primary:hover {
    background: rgba(99, 102, 241, 0.2);
    border-color: rgba(99, 102, 241, 0.3);
    color: #a5b4fc;
  }
</style>
